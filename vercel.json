{
  "version": 2,
  "builds": [
    {
      "src": "demistifying_xG.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "demistifying_xG.py"
    }
  ],
  "env": {
    "PYTHONPATH": "/var/task"
  }
}
